# Ambientes Virtuais
.venv/
venv/
env/
ENV/

# Python cache e executáveis compilados
__pycache__/
*.py[cod]
*$py.class
*.so

# Banco de dados local (geralmente ignorado no log versionado, use backups ou migrações)
db.sqlite3
db.sqlite3-journal

