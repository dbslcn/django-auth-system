.env
.env.local

# Logs
*.log
logs/

# IDE e ferramentas
.vscode/
.idea/
.DS_Store

# Static assets coletados pelo Django
staticfiles/
static_root/

# Mídias carregadas por usuários
media/

# Node_modules (caso adicione frontend no futuro)
node_modules/

# pytest ou coverage (se for rodar testes locais futuramente)
.pytest_cache/
.coverage
htmlcov/
